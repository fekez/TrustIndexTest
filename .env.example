# ============================================================
# APPLICATION ENVIRONMENT
# ============================================================
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
#
#   cp .env.example .env
#
# This file is also used in CI: the pipeline copies it to .env
# before running any commands. All values here must be valid
# enough for the test suite to boot.
# ============================================================

# ------------------------------------------------------------
# Symfony Framework
# ------------------------------------------------------------

# Application environment: dev | test | prod
APP_ENV=dev

# A random 32+ character string used for cryptographic signing.
# Generate one with: php -r "echo bin2hex(random_bytes(16));"
# CI uses this placeholder value – never use it in production.
APP_SECRET=aaaabbbbccccdddd1111222233334444

# Shared directory for cross-request state (used by Symfony internally)
APP_SHARE_DIR=var/share

# ------------------------------------------------------------
# Routing
# ------------------------------------------------------------

# Base URL used when generating URLs outside of HTTP context (e.g. CLI commands)
DEFAULT_URI=http://localhost

# ------------------------------------------------------------
# Database (Doctrine / PostgreSQL)
# ------------------------------------------------------------

# Full DSN for the application database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?serverVersion=VERSION&charset=utf8
#
# Docker Compose default values:
#   host     = postgres  (service name)
#   port     = 5432
#   user     = app
#   password = secret
#   dbname   = trustindex
#
# In CI this value is overridden by the job-level env var.
DATABASE_URL="postgresql://app:secret@postgres:5432/trustindex?serverVersion=16&charset=utf8"
