# ============================================================
# PRODUCTION ENVIRONMENT
# ============================================================
# Copy this file to .env for production deployment:
#
#   cp .env.prod.example .env
#
# ============================================================

# ------------------------------------------------------------
# Symfony Framework
# ------------------------------------------------------------

APP_ENV=prod
APP_DEBUG=false
APP_SECRET=aaaabbbbccccdddd1111222233334444
APP_SHARE_DIR=var/share

# ------------------------------------------------------------
# Routing
# ------------------------------------------------------------

DEFAULT_URI=http://localhost

# ------------------------------------------------------------
# Database (Doctrine / PostgreSQL)
# ------------------------------------------------------------

DATABASE_URL="postgresql://app:secret@postgres:5432/trustindex?serverVersion=16&charset=utf8"
