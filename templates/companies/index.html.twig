{% extends 'base.html.twig' %}

{% block title %}Cégrangsor{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Cégrangsor</h1>
    <a href="{{ path('review_new') }}" class="btn btn-primary">+ Új vélemény</a>
</div>

<form method="get" action="{{ path('companies_index') }}" class="mb-4">
    <div class="input-group" style="max-width: 400px;">
        <input
            type="search"
            name="q"
            class="form-control"
            placeholder="Keresés cég neve alapján…"
            value="{{ query }}"
            aria-label="Keresés"
        >
        <button class="btn btn-outline-secondary" type="submit">Keresés</button>
        {% if query %}
            <a href="{{ path('companies_index') }}" class="btn btn-outline-danger">×</a>
        {% endif %}
    </div>
</form>

{% if query %}
    <p class="text-muted small mb-3">
        Találatok erre: <strong>„{{ query }}"</strong>
        {% if pagination is empty %} – nincs találat{% endif %}
    </p>
{% endif %}

{% if pagination is empty %}
    <div class="alert alert-info">
        {% if query %}
            Nincs találat a megadott keresési feltételre.
        {% else %}
            Még nincs vélemény a rendszerben.
        {% endif %}
    </div>
{% else %}
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Cég neve</th>
                        <th class="text-center">Vélemények</th>
                        <th class="text-center">Átlagos értékelés</th>
                        <th class="text-center">Csillagok</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in pagination %}
                    <tr>
                        <td class="ps-3 text-muted">{{ loop.index }}</td>
                        <td class="fw-semibold">{{ row.company_name }}</td>
                        <td class="text-center">{{ row.review_count }}</td>
                        <td class="text-center">
                            <span class="badge bg-primary">{{ row.average_rating }}</span>
                        </td>
                        <td class="text-center text-warning">
                            {% set full = row.average_rating|round(0, 'floor') %}
                            {% for i in 1..5 %}
                                {{ i <= full ? '★' : '☆' }}
                            {% endfor %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(pagination) }}
    </div>
{% endif %}
{% endblock %}
