{% extends 'base.html.twig' %}

{% block title %}Vélemények{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Vélemények</h1>
    <a href="{{ path('review_new') }}" class="btn btn-primary">+ Új vélemény</a>
</div>

{% if reviews is empty %}
    <div class="alert alert-info">Még nincs vélemény. Legyél az első!</div>
{% else %}
    <div class="row g-3">
        {% for review in reviews %}
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title mb-1">{{ review.companyName }}</h5>
                        <small class="text-muted">{{ review.createdAt|date('Y. m. d.') }}</small>
                    </div>
                    <div class="text-warning mb-2" aria-label="{{ review.rating }} csillag az 5-ből">
                        {% for i in 1..5 %}
                            {{ i <= review.rating ? '★' : '☆' }}
                        {% endfor %}
                        <span class="text-muted small">({{ review.rating }}/5)</span>
                    </div>
                    <p class="card-text text-secondary mb-2">
                        {{ review.reviewText|length > 120
                            ? review.reviewText|slice(0, 120) ~ '…'
                            : review.reviewText }}
                    </p>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">{{ review.authorEmail }}</small>
                        <a href="{{ path('review_show', {id: review.id}) }}" class="btn btn-sm btn-outline-secondary">
                            Részletek →
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
