{% extends 'base.html.twig' %}

{% block title %}Új vélemény{% endblock %}

{% block stylesheets %}
    <style>
        .star-rating {
            display: flex;
            gap: 4px;
        }
        .star {
            font-size: 2rem;
            color: #ccc;
            cursor: pointer;
            transition: color 0.15s;
            user-select: none;
        }
        .star.selected,
        .star.hovered {
            color: #f5a623;
        }
    </style>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h4 class="mb-0">Új vélemény írása</h4>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-3">
                    {{ form_label(form.companyName, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.companyName, {'attr': {'class': 'form-control' ~ (form.companyName.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                    {{ form_errors(form.companyName) }}
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Értékelés</label>
                    <div class="star-rating mb-1">
                        {% for i in 1..5 %}
                            <span class="star" data-value="{{ i }}">★</span>
                        {% endfor %}
                    </div>
                    <small class="text-muted star-label">Kattints egy csillagra</small>
                    {{ form_widget(form.rating) }}
                    {{ form_errors(form.rating) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.reviewText, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.reviewText, {'attr': {'class': 'form-control' ~ (form.reviewText.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                    {{ form_errors(form.reviewText) }}
                </div>

                <div class="mb-4">
                    {{ form_label(form.authorEmail, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.authorEmail, {'attr': {'class': 'form-control' ~ (form.authorEmail.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                    {{ form_errors(form.authorEmail) }}
                </div>

                <div class="d-grid">
                    {{ form_widget(form.submit) }}
                </div>

                {{ form_end(form) }}
            </div>
        </div>
        <div class="mt-3 text-center">
            <a href="{{ path('review_index') }}" class="text-muted small">← Vissza a listához</a>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const stars = document.querySelectorAll('.star');
            const input = document.getElementById('review_rating');
            const label = document.querySelector('.star-label');
            const labels = ['', 'Nagyon rossz', 'Rossz', 'Közepes', 'Jó', 'Kiváló'];

            // default: 5 csillag, vagy a már beküldött érték
            const currentValue = parseInt(input.value) || 5;
            input.value = currentValue;
            updateStars(currentValue);

            stars.forEach(function (star) {
                star.addEventListener('mouseenter', function () {
                    const val = parseInt(this.dataset.value);
                    stars.forEach(s => {
                        s.classList.toggle('hovered', parseInt(s.dataset.value) <= val);
                    });
                });

                star.addEventListener('mouseleave', function () {
                    stars.forEach(s => s.classList.remove('hovered'));
                });

                star.addEventListener('click', function () {
                    const val = parseInt(this.dataset.value);
                    input.value = val;
                    updateStars(val);
                    label.textContent = labels[val];
                });
            });

            function updateStars(val) {
                stars.forEach(s => {
                    s.classList.toggle('selected', parseInt(s.dataset.value) <= val);
                });
                label.textContent = labels[val];
            }
        });
    </script>
{% endblock %}
