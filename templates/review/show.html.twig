{% extends 'base.html.twig' %}

{% block title %}{{ review.companyName }} – Vélemény{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">

        <div class="mb-3">
            <a href="{{ path('review_index') }}" class="text-muted small">← Vissza a listához</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">{{ review.companyName }}</h4>
                <small class="text-muted">{{ review.createdAt|date('Y. m. d. H:i') }}</small>
            </div>
            <div class="card-body">

                <div class="text-warning fs-4 mb-3" aria-label="{{ review.rating }} csillag az 5-ből">
                    {% for i in 1..5 %}
                        {{ i <= review.rating ? '★' : '☆' }}
                    {% endfor %}
                    <span class="text-muted fs-6 ms-1">({{ review.rating }}/5)</span>
                </div>

                <p class="card-text mb-4">{{ review.reviewText }}</p>

                <hr>

                <div class="d-flex justify-content-between text-muted small">
                    <span>✉ {{ review.authorEmail }}</span>
                    <span>Módosítva: {{ review.updatedAt|date('Y. m. d. H:i') }}</span>
                </div>

            </div>
        </div>

        <div class="mt-3 d-flex justify-content-between align-items-center">
            <a href="{{ path('review_index') }}" class="text-muted small">← Vissza a listához</a>
            <form method="post" action="{{ path('review_delete', {id: review.id}) }}"
                  onsubmit="return confirm('Biztosan törölni szeretnéd?')">
                <button type="submit" class="btn btn-sm btn-outline-danger">Vélemény törlése</button>
            </form>
        </div>

        <div class="mt-3 text-center">
            <a href="{{ path('companies_index') }}" class="text-muted small">
                Cégrangsor megtekintése →
            </a>
        </div>

    </div>
</div>
{% endblock %}
